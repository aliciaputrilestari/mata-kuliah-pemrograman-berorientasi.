<div class="card">
<h2>2. Named Constructor – Class Sepeda</h2>
<pre>
class Sepeda {
  String? merk;
  int? gear;

  Sepeda(this.merk, this.gear);

  Sepeda.standard() {
    merk = "Polygon";
    gear = 21;
  }
}

void main() {
  var sepeda1 = Sepeda.standard();

  print(sepeda1.merk);
  print(sepeda1.gear);
}
</pre>
</div>

<div class="card">
<h2>3. Constant Constructor</h2>
<pre>
class Ukuran {
  final int panjang;
  final int lebar;

  const Ukuran(this.panjang, this.lebar);
}

void main() {
  const meja = Ukuran(120,60);

  print("${meja.panjang} x ${meja.lebar}");
}
</pre>
</div>

<div class="card">
<h2>4. Initializer List</h2>
<pre>
class Segitiga {
  double alas;
  double tinggi;
  double luas;

  Segitiga(this.alas, this.tinggi)
  : luas = 0.5 * alas * tinggi;
}

void main() {
  var s = Segitiga(8,6);

  print(s.luas);
}
</pre>
</div>

<div class="card">
<h2>5. Getter</h2>
<pre>
class Film {
  String _judul;

  Film(this._judul);

  String get judul => _judul;
}

void main() {
  var film = Film("Avengers");

  print(film.judul);
}
</pre>
