<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Portfolio Tugas OOP</title>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Segoe UI;
}

body{
background:linear-gradient(135deg,#ff9bd2,#7aa6ff);
min-height:100vh;
color:white;
}

/* HEADER */

header{
text-align:center;
padding:40px 20px;
animation:fadeDown 1s ease;
}

header h1{
font-size:40px;
text-shadow:0 0 15px #ff6ec7;
}

.profile{
margin-top:15px;
display:inline-block;
padding:15px 25px;
border-radius:20px;
background:rgba(255,255,255,0.2);
backdrop-filter:blur(10px);
box-shadow:0 0 20px #ff9bd2;
}

/* GRID */

.container{
max-width:1100px;
margin:auto;
padding:20px;

display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

/* CARD */

.card{
background:white;
color:#333;
padding:20px;
border-radius:20px;
text-align:center;

box-shadow:0 10px 30px rgba(0,0,0,0.2);

transition:0.4s;
position:relative;
overflow:hidden;
}

.card:hover{
transform:translateY(-10px) scale(1.03);
box-shadow:0 0 30px #ff6ec7;
}

.card i{
font-size:40px;
margin-bottom:10px;
color:#ff4fa3;
}

/* BUTTON */

.btn{
margin-top:15px;
padding:10px 18px;
border:none;
border-radius:20px;
cursor:pointer;

background:linear-gradient(45deg,#ff6ec7,#7aa6ff);
color:white;
font-weight:bold;

box-shadow:0 0 15px #ff6ec7;
transition:0.3s;
}

.btn:hover{
transform:scale(1.1);
box-shadow:0 0 25px #7aa6ff;
}

/* POPUP */

.popup{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.7);

display:none;
align-items:center;
justify-content:center;
z-index:999;
}

.popup-content{
width:90%;
height:80%;
background:white;
border-radius:20px;
overflow:hidden;
position:relative;
}

.popup iframe{
width:100%;
height:100%;
border:none;
}

.close{
position:absolute;
top:10px;
right:15px;
font-size:25px;
cursor:pointer;
color:red;
}

/* FOOTER */

footer{
text-align:center;
padding:20px;
margin-top:30px;
font-size:14px;
}

/* ANIMATION */

@keyframes fadeDown{
from{
opacity:0;
transform:translateY(-40px);
}
to{
opacity:1;
transform:translateY(0);
}
}

</style>
</head>

<body>

<header>

<h1>🌸 Portfolio Tugas OOP 🌸</h1>

<div class="profile">
<b>Nama:</b> Alicia Putri Lestari <br>
<b>NIM:</b> 251410011 <br>
<b>Kelas:</b> SI2A
</div>

</header>


<div class="container">

<div class="card">
<i class="fa-solid fa-code"></i>
<h3>Constructor</h3>
<p>Contoh penggunaan constructor pada Dart.</p>
<button class="btn" onclick="openCode('https://dartpad.dev/')">Run Code</button>
</div>


<div class="card">
<i class="fa-solid fa-bolt"></i>
<h3>Named Constructor</h3>
<p>Constructor dengan nama khusus.</p>
<button class="btn" onclick="openCode('https://dartpad.dev/')">Run Code</button>
</div>


<div class="card">
<i class="fa-solid fa-gem"></i>
<h3>Constant Constructor</h3>
<p>Constructor untuk objek immutable.</p>
<button class="btn" onclick="openCode('https://dartpad.dev/')">Run Code</button>
</div>


<div class="card">
<i class="fa-solid fa-diagram-project"></i>
<h3>Initializer List</h3>
<p>Inisialisasi nilai sebelum constructor.</p>
<button class="btn" onclick="openCode('https://dartpad.dev/')">Run Code</button>
</div>


<div class="card">
<i class="fa-solid fa-lock"></i>
<h3>Getter</h3>
<p>Mengambil data private.</p>
<button class="btn" onclick="openCode('https://dartpad.dev/')">Run Code</button>
</div>


<div class="card">
<i class="fa-solid fa-key"></i>
<h3>Setter</h3>
<p>Mengubah data private.</p>
<button class="btn" onclick="openCode('https://dartpad.dev/')">Run Code</button>
</div>


<div class="card">
<i class="fa-solid fa-shield"></i>
<h3>Encapsulation</h3>
<p>Melindungi data dalam class.</p>
<button class="btn" onclick="openCode('https://dartpad.dev/')">Run Code</button>
</div>


<div class="card">
<i class="fa-solid fa-user-lock"></i>
<h3>Sistem Login</h3>
<p>Contoh login sederhana.</p>
<button class="btn" onclick="openCode('https://dartpad.dev/')">Run Code</button>
</div>

</div>


<div class="popup" id="popup">
<div class="popup-content">

<span class="close" onclick="closeCode()">✖</span>

<iframe id="dartframe"></iframe>

</div>
</div>


<footer>
✨ Website Tugas OOP - Alicia Putri Lestari ✨
</footer>


<script>

function openCode(url){
document.getElementById("popup").style.display="flex";
document.getElementById("dartframe").src=url;
}

function closeCode(){
document.getElementById("popup").style.display="none";
document.getElementById("dartframe").src="";
}

</script>

</body>
</html>
