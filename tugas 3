<div class="card">
<h2>7. Enkapsulasi – Class Rekening</h2>
<pre>
class Rekening {
  String _namaPemilik = "";
  double _saldo = 0;

  String get namaPemilik => _namaPemilik;
  double get saldo => _saldo;

  set namaPemilik(String value){
    _namaPemilik = value;
  }

  void tambahSaldo(double jumlah){
    if(jumlah > 0){
      _saldo += jumlah;
    }
  }
}
</pre>
